# =====================================================
# Supabase (EU-Region Frankfurt empfohlen)
# =====================================================
# Erhältlich unter https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service-Role-Key NIEMALS in Client-Bundles aufnehmen!
# Nur in Server-Routes / Edge Functions verwenden.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Für Expo (gleiche Werte wie NEXT_PUBLIC_*)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# =====================================================
# Email (Resend EU)
# =====================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@mieterplus.example

# =====================================================
# Monitoring (optional, empfohlen für Produktion)
# =====================================================
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# =====================================================
# App
# =====================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
