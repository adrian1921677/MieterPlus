# Kopiere diese Datei zu `.env.local` und fülle die Werte aus.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mapbox (Public-Token: account.mapbox.com → Tokens. Beginnt mit "pk.")
NEXT_PUBLIC_MAPBOX_TOKEN=pk.YOUR-MAPBOX-PUBLIC-TOKEN

# Resend (transaktionale E-Mails — Termin-Benachrichtigungen)
RESEND_API_KEY=re_YOUR-RESEND-API-KEY
RESEND_FROM_EMAIL=noreply@abdullahu.de

# Stripe (Abo — solange leer: manuelle Freischaltung durch Admin)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price-IDs aus dem Stripe-Dashboard (beginnen mit price_...)
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
